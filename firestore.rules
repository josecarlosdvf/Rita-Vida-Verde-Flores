rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.active is bool &&
             data.slug is string && data.slug.matches('^[a-z0-9-]+$') &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidBanner(data) {
      return data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.order is int &&
             data.active is bool &&
             (!('link' in data) || (data.link is string && data.link.size() <= 500)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidSettings(data) {
      return data.companyName is string && data.companyName.size() <= 100 &&
             data.whatsappNumber is string && data.whatsappNumber.size() <= 20 &&
             (!('primaryColor' in data) || (data.primaryColor is string && data.primaryColor.size() <= 20)) &&
             (!('secondaryColor' in data) || (data.secondaryColor is string && data.secondaryColor.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500));
    }

    function isValidReview(data) {
      return data.productId is string && isValidId(data.productId) &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.approved is bool &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() <= 100 &&
             data.customerPhone is string && data.customerPhone.size() <= 30 &&
             data.customerAddress is string && data.customerAddress.size() <= 500 &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // --- Rules ---

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && 
                    incoming().keys().hasAll(['name', 'price', 'imageUrl', 'active', 'slug', 'createdAt', 'updatedAt']);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'imageUrl', 'active', 'slug', 'updatedAt', 'rating', 'reviewsCount'])
      );
      allow delete: if isAdmin();
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBanner(incoming());
      allow update: if isAdmin() && isValidBanner(incoming());
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(incoming()) && incoming().approved == false; // Customer reviews start unapproved
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if false; 
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'maxSessions', 'sessionPolicy'])
      );
      allow delete: if isAdmin() && userId != request.auth.uid;
    }
  }
}
