{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite --host",
    "api": "npx tsx api-server.ts",
    "dev:all": "kill-port 3010 8082 && concurrently -k -n API,WEB -c green,blue \"npm:api\" \"npm:dev\"",
    "start": "npx tsx api-server.ts",
